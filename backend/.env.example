# ── Server ────────────────────────────────────────────────────────────────────
# Render injects PORT automatically. Set here only for local dev.
PORT=5000

NODE_ENV=development   # set to "production" on Render

# ── Database ──────────────────────────────────────────────────────────────────
# Local MySQL:
#   DATABASE_URL="mysql://USER:PASSWORD@localhost:3307/cryptobank"
#
# TiDB Cloud Serverless (production):
#   DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/cryptobank?sslaccept=strict"
#   HOST looks like: gateway01.us-east-1.prod.aws.tidbcloud.com
#
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/cryptobank"

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — app will exit on startup if missing.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://your-app.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── App config ────────────────────────────────────────────────────────────────
# Email address whose wallets act as the fee collector account.
FEE_COLLECTOR_EMAIL=admin@cryptobank.com

# PLACEHOLDER — do NOT put a real mainnet address here.
USDT_TRC20_DEPOSIT_ADDRESS=REPLACE_WITH_YOUR_TRC20_USDT_ADDRESS
